# ============================================================
# Signal Backend — Environment Variables
# Copy to .env and fill in your values
# ============================================================

# Anthropic API key — get from console.anthropic.com
ANTHROPIC_API_KEY=XXXXX

# OpenAI API key — get from platform.openai.com
# Used ONLY for text-embedding-3-small (1536-dim vectors)
OPENAI_API_KEY=XXXXX

# Supabase — get all three from:
# supabase.com → your project → Settings → API
SUPABASE_URL=https://XXXXX.supabase.co
SUPABASE_ANON_KEY=XXXXX
SUPABASE_SERVICE_ROLE_KEY=XXXXX

# APNs Push Notifications — get from Apple Developer account
# APNS_KEY: contents of your .p8 key file (including -----BEGIN/END PRIVATE KEY----- lines)
APNS_KEY=XXXXX
APNS_KEY_ID=XXXXXXXXXX
APNS_TEAM_ID=XXXXXXXXXX
APNS_BUNDLE_ID=com.yourname.signal

# Server
PORT=3001
NODE_ENV=development
